{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Kids Lite",
  "version": "0.1.0",
  "identifier": "com.ytkids.lite",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "YouTube Kids Lite",
        "width": 1000,
        "height": 600,
        "url": "https://www.youtubekids.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
