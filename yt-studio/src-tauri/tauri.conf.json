{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YT Studio - Streamer Edition",
  "version": "0.1.0",
  "identifier": "com.ytstudio.streamer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "YT Studio - Streamer Edition",
        "width": 1280,
        "height": 720,
        "url": "https://studio.youtube.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
